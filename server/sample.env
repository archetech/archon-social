# archon.social server environment — standalone deployment
#
# Copy to .env and edit. The server reads this file via dotenv.

# Required
ARCHON_HERALD_SESSION_SECRET=change-me-to-a-long-random-string
ARCHON_GATEKEEPER_URL=http://localhost:4224

# Public URL override (IMPORTANT for standalone deployment)
# In the monorepo, Herald is mounted under /names by Drawbridge, so it derives
# its public URL as ${ARCHON_DRAWBRIDGE_PUBLIC_HOST}/names. A standalone
# deployment like archon.social sits at the domain root, so set this explicitly
# to prevent callback URLs from pointing at Drawbridge paths.
ARCHON_HERALD_PUBLIC_URL=https://archon.social

# Service identity
ARCHON_HERALD_NAME=archon-social
ARCHON_HERALD_DOMAIN=archon.social
ARCHON_HERALD_OWNER_DID=did:cid:bagaaiera7vsjlu6oiluzd4enop5j7sfzjbwp2ujudt6uunkz6hhd4lgfe4sa

# Server port (nginx proxies here)
ARCHON_HERALD_PORT=4230

# Data directory (sqlite / json db files)
ARCHON_HERALD_DATA_DIR=./data

# Keymaster / wallet
ARCHON_HERALD_WALLET_URL=https://wallet.archon.technology
ARCHON_HERALD_WALLET_PASSPHRASE=
ARCHON_HERALD_KEYMASTER_URL=

# Database backend: json (default), sqlite, or redis
ARCHON_HERALD_DB=json

# IPFS for registry publication
ARCHON_HERALD_IPFS_API_URL=http://localhost:5001/api/v0
ARCHON_HERALD_IPNS_KEY_NAME=archon-social

# Membership credential schema (override if you want a custom VC schema)
# ARCHON_HERALD_MEMBERSHIP_SCHEMA_DID=did:cid:...

# OAuth / OIDC JWT signing key path (relative to DATA_DIR)
ARCHON_HERALD_JWT_KEY_PATH=jwt

# Admin API key for internal service-to-service calls (optional)
# ARCHON_HERALD_ADMIN_API_KEY=
