# Service identity
NS_SERVICE_NAME=name-service
NS_SERVICE_DOMAIN=your-domain.example
NS_PUBLIC_URL=https://your-domain.example
NS_SESSION_SECRET=change-me-to-a-random-string
NS_OWNER_DID=did:cid:your-owner-did

# Server settings
NS_SERVE_CLIENT=true
NS_CORS_SITE_ORIGIN=http://localhost:3001
NS_DATABASE=json
NS_HOST_PORT=3300

# Archon services (use container names when running in docker)
NS_GATEKEEPER_URL=http://archon-gatekeeper-1:4224
NS_KEYMASTER_URL=http://archon-keymaster-1:4226
NS_WALLET_URL=http://archon-gatekeeper-1:4224
NS_WALLET_PASSPHRASE=

# IPNS publication settings (use container name for IPFS)
NS_IPFS_API_URL=http://localhost:5001/api/v0
NS_IPNS_KEY_NAME=name-service

# Membership credential schema DID
NS_MEMBERSHIP_SCHEMA_DID=did:cid:bagaaieraj6e2ygpm7laaapxuz5efo2bxi436vi6ubw42b75elsscelte6kza

# Tor SOCKS proxy for .onion Lightning endpoints (e.g. localhost:9050)
NS_TOR_PROXY=
